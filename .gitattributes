# Force Unix line endings for shell scripts
gradlew        text eol=lf
*.sh           text eol=lf

# Windows batch files need CRLF
gradlew.bat    text eol=crlf
*.bat          text eol=crlf

# Mark gradlew as executable in git (preserves chmod +x across clones)
gradlew        linguist-language=Shell

# Binary files — no line ending conversion
*.jar          binary
*.png          binary
*.jpg          binary
*.apk          binary
*.keystore     binary
*.jks          binary
