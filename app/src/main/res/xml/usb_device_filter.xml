<?xml version="1.0" encoding="utf-8"?>
<!--
    USB device filter for TinyRAD FMCW radar board.
    IMPORTANT: vendor-id and product-id must be DECIMAL integers.
    Android's UsbManager compares these as integers, not hex strings.

    Analog Devices TinyRAD: VID=0x0456 (1110), PID=0xB671 (46705)
    STM32 CDC-ACM fallback:  VID=0x0483 (1155), PID=0x5740 (22336)
-->
<resources>
    <usb-device vendor-id="1110"  product-id="46705" />
    <usb-device vendor-id="1155"  product-id="22336" />
</resources>
