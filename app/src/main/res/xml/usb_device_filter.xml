<?xml version="1.0" encoding="utf-8"?>
<!--
    USB device filter for EV-TINYRAD24G (UG-1709)
    ADSP-BF706 Blackfin DSP — appears as "BF707 Bulk Device"

    Android parses vendor-id and product-id as DECIMAL integers.

    VID 0x064B = 1611  — "Analog Devices, Inc. Development Tools"
                          (second ADI VID used for eval/firmware boards)
    VID 0x0456 = 1110  — "Analog Devices, Inc." (production silicon)

    Confirmed pair from EV-TINYRAD24G firmware R 3.0.3 (2020-06-02):
      VID 0x064B (1611)  PID 0x7823 (30755)

    Legacy/alternate pairs kept as fallback:
      VID 0x0456 + various BF70x PIDs from older firmware revisions
-->
<resources>
    <!-- ── Confirmed: EV-TINYRAD24G firmware R 3.0.3 ── -->
    <usb-device vendor-id="1611" product-id="30755" />

    <!-- ── Fallback: older TinyRad / DemoRad firmware (VID 0x0456) ── -->
    <usb-device vendor-id="1110" product-id="46607" />
    <usb-device vendor-id="1110" product-id="46705" />
    <usb-device vendor-id="1110" product-id="46636" />
    <usb-device vendor-id="1110" product-id="46627" />

    <!-- ── Fallback: STM32 CDC-ACM custom firmware ── -->
    <usb-device vendor-id="1155" product-id="22336" />
</resources>
